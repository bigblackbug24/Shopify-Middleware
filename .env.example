# ── App ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ── MySQL ─────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=shopify_middleware
DB_USER=root
DB_PASSWORD=secret

# ── Redis ─────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Shopify ───────────────────────────────────────
# Your store domain (no https://)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Admin API Access Token (from private app)
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxx

# Webhook Secret (from Shopify webhook settings)
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here

# API version — update quarterly
SHOPIFY_API_VERSION=2024-01

# ── Queue ─────────────────────────────────────────
QUEUE_NAME=order-processing
QUEUE_CONCURRENCY=5
JOB_MAX_ATTEMPTS=3
JOB_BACKOFF_DELAY=5000

# ── Logging ───────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ── Dev Flags ─────────────────────────────────────
# Set to true if you don't have a real Shopify store
USE_MOCK_SHOPIFY=false
