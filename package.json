{
  "name": "shopify-middleware",
  "version": "1.0.0",
  "description": "Shopify Webhook Middleware - Async order processing with Redis queue and MySQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker": "node src/workers/workerRunner.js",
    "worker:dev": "nodemon src/workers/workerRunner.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:status": "knex migrate:status",
    "migrate:make": "knex migrate:make",
    "lint": "eslint src/",
    "test": "jest"
  },
  "dependencies": {
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "@bull-board/ui": "^7.0.0",
    "axios": "^1.6.0",
    "bottleneck": "^2.19.5",
    "bullmq": "^5.0.0",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "ioredis": "^5.3.0",
    "joi": "^17.11.0",
    "knex": "^3.1.0",
    "mysql2": "^3.6.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
